        { "id": "i17csm_e6", "from": "i17csm_rev", "to": "i17csm_prof", "event": "CSM_RESTORED" },
        { "id": "i17csm_e7", "from": "i17csm_oner", "to": "i17csm_prof", "event": "FAVORABLE_CHANGE" }
      ],
      "initialStateId": "i17csm_prof",
      "finalStateIds": ["i17csm_prof"]
    },

