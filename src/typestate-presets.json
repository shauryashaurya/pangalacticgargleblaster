      ],
      "initialStateId": "i17c_new",
      "finalStateIds": ["i17c_gmm", "i17c_vfa", "i17c_paa"]
    },
    "ifrs17_csmTracking": {
      "label": "IFRS 17: CSM / Loss Component",
      "category": "IFRS 17",
      "description": "Tracks whether a contract group is profitable (positive CSM) or onerous (loss component recognized). CSM absorbs favourable/unfavourable changes; when depleted, a loss is recognized in P&L.",
      "nodes": [
        { "id": "i17csm_prof", "name": "PROFITABLE", "x": 140, "y": 160 },
        { "id": "i17csm_oner", "name": "ONEROUS", "x": 400, "y": 160 },
        { "id": "i17csm_loss", "name": "LOSS_IN_PL", "x": 400, "y": 320 },
        { "id": "i17csm_rev", "name": "LOSS_REVERSED", "x": 140, "y": 320 }
      ],
      "edges": [
        { "id": "i17csm_e1", "from": "i17csm_prof", "to": "i17csm_prof", "event": "UNFAV_ABSORBED" },
        { "id": "i17csm_e2", "from": "i17csm_prof", "to": "i17csm_oner", "event": "CSM_DEPLETED" },
        { "id": "i17csm_e3", "from": "i17csm_oner", "to": "i17csm_loss", "event": "RECOGNIZE_LOSS" },
        { "id": "i17csm_e4", "from": "i17csm_loss", "to": "i17csm_loss", "event": "FURTHER_LOSS" },
